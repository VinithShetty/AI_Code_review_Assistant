# Simple Dockerfile for the current repo layout (single Next.js app at repo root)

FROM node:20-alpine AS development

WORKDIR /app

# Install deps first for better layer caching
COPY package.json package-lock.json* ./
RUN npm ci

# Copy app sources
COPY . .

ENV NEXT_TELEMETRY_DISABLED=1
ENV PORT=3000

EXPOSE 3000

CMD ["npm", "run", "dev"]
