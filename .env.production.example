# ─────────────────────────────────────────────────────────────────────────────
# CodeReview AI — PRODUCTION environment template
#
# Copy to `.env.production` on your server and fill every value.
# NEVER commit the real .env.production (it is gitignored).
#
#   cp .env.production.example .env.production
#   $EDITOR .env.production
# ─────────────────────────────────────────────────────────────────────────────

# The public domain Caddy serves + provisions HTTPS for. No protocol, no slash.
DOMAIN=codereview.example.com

# App base URL used by NextAuth. Must be https://<DOMAIN>.
NEXTAUTH_URL=https://codereview.example.com

# JWT/session signing secret. Generate: openssl rand -base64 32
NEXTAUTH_SECRET=CHANGE_ME

# GitHub OAuth App — create at https://github.com/settings/developers
# Authorization callback URL to register: https://<DOMAIN>/api/auth/callback/github
GITHUB_CLIENT_ID=CHANGE_ME
GITHUB_CLIENT_SECRET=CHANGE_ME

# Database — set by docker-compose.prod.yml to a SQLite file on a named volume.
# Leave as-is unless you migrate to Postgres.
DATABASE_URL=file:/app/db/prod.db

# ─── Optional: GitHub App (server-to-server) + webhooks ──────────────────────
GITHUB_WEBHOOK_SECRET=
GITHUB_APP_ID=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_PRIVATE_KEY_PATH=
GITHUB_DEFAULT_INSTALLATION_ID=
